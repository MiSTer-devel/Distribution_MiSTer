    </interleave>
    <interleave output="16">
      <part name="a96_35-1.191" crc="b3280193" map="10"/>
      <part name="a96_34-1.158" crc="ca3b2573" map="01"/>
    </interleave>

    <!-- Sprite ROM -->
    <interleave output="32">
      <part name="a96_47.201" crc="8df9286a" map="1000"/>
      <part name="a96_46.180" crc="fec35418" map="0100"/>
      <part name="a96_45.200" crc="616cdd8b" map="0010"/>
