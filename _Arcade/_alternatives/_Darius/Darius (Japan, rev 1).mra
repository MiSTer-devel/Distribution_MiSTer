<misterromdescription>
  <name>Darius (Japan, rev 1)</name>
  <setname>dariusj</setname>
  <mameversion>0264</mameversion>
  <rbf>Darius</rbf>
  <year>1986</year>
  <manufacturer>Taito Corporation</manufacturer>
  <category>Shooter</category>
  <rotation>horizontal</rotation>
  <resolution>15kHz</resolution>
  <players>2</players>
  <joystick>8-way</joystick>
  <num_buttons>2</num_buttons>
  <buttons default="A,B,Start" names="Shot,Bomb,-,-,-,-,Start,Coin,Pause"/>

  <switches default="FF,FF">
    <!-- SW1 (bits 0-7) — active LOW: bit=1=OFF (default) -->
    <dip bits="0"   ids="On,Off" name="Unknown (SW1:1)"/>
    <dip bits="1"   ids="On,Off" name="Autofire"/>
    <dip bits="2"   ids="On,Off" name="Service Mode"/>
    <dip bits="3"   ids="Off,On" name="Demo Sounds"/>
    <dip bits="4,5" ids="2C/3C,1C/2C,2C/1C,1C/1C" name="Coin A"/>
    <dip bits="6,7" ids="2C/3C,1C/2C,2C/1C,1C/1C" name="Coin B"/>
    <!-- SW2 (bits 8-15) -->
    <dip bits="8,9"   ids="Hardest,Hard,Easy,Medium" name="Difficulty"/>
    <dip bits="10,11" ids="None,800K,400K,600K" name="Bonus Life"/>
    <dip bits="12,13" ids="6,5,4,3" name="Lives"/>
    <dip bits="14"    ids="On,Off" name="Unknown (SW2:7)"/>
    <dip bits="15"    ids="On,Off" name="Unknown (SW2:8)"/>
  </switches>

  <rom index="1">
    <part>00</part>
  </rom>
  <rom index="0" zip="darius.zip|dariusj.zip" md5="None">
    <!-- Tile ROM -->
    <interleave output="16">
      <part name="a96_48.24" crc="39c9b3aa" map="10"/>
      <part name="a96_51.47" crc="1bf8f0d3" map="01"/>
    </interleave>
    <interleave output="16">
      <part name="a96_49.25" crc="37a7d88a" map="10"/>
      <part name="a96_52.48" crc="2d9b2128" map="01"/>
    </interleave>
    <interleave output="16">
      <part name="a96_50.26" crc="75d738e4" map="10"/>
      <part name="a96_53.49" crc="0173484c" map="01"/>
    </interleave>

    <!-- Main CPU ROM (128KB + 128KB data, middle empty filled 0xFF) -->
    <interleave output="16">
      <part name="a96_29-1.185" crc="75486f62" map="10"/>
      <part name="a96_28-1.152" crc="fb34d400" map="01"/>
    </interleave>
    <part repeat="0x20000">FF</part>
    <interleave output="16">
      <part name="a96_31.188" crc="e9bb5d89" map="10"/>
      <part name="a96_30.154" crc="9eb5e127" map="01"/>
